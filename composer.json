{
    "name": "capslock/qa-api-task",
    "description": "Capslock QA test task — Media Buyers API automation with Codeception, Allure and Qase reporters.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "codeception/codeception": "^5.1",
        "codeception/module-rest": "^3.4",
        "codeception/module-phpbrowser": "^3.0",
        "codeception/module-asserts": "^3.0",
        "justinrainbow/json-schema": "^5.2",
        "fakerphp/faker": "^1.23",
        "vlucas/phpdotenv": "^5.6",
        "allure-framework/allure-codeception": "^2.4",
        "qase/codeception-reporter": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/_support/"
        }
    },
    "config": {
        "allow-plugins": {
            "codeception/c3": true
        }
    }
}
