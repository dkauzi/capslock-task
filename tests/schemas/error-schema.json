{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorResponse",
  "type": "object",
  "properties": {
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "detail": { "type": "string", "minLength": 1 }
        },
        "required": ["detail"]
      }
    }
  },
  "required": ["errors"]
}
